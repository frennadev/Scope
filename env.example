# 0G Storage Configuration
# Copy this file to .env.local and replace with your actual values

# 0G Storage Private Key (required for storage operations)
ZEROG_PRIVATE_KEY=your_private_key_here

# Alternative (for Next.js public access)  
NEXT_PUBLIC_ZEROG_PRIVATE_KEY=your_private_key_here

# 0G Network Configuration (optional - defaults are set in code)
# ZEROG_RPC_URL=https://evmrpc-testnet.0g.ai/
# ZEROG_INDEXER_RPC=https://indexer-storage-testnet-turbo.0g.ai
# ZEROG_KV_RPC=http://3.101.147.150:6789

# Usage Instructions:
# 1. Copy this file: cp env.example .env.local
# 2. Replace 'your_private_key_here' with your actual 0G Storage private key
# 3. Restart your development server: npm run dev
